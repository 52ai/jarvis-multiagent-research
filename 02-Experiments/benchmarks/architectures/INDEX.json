    "repetitions": 3,
    "total_runs": 60
  },
  "scoring_dimensions": {
    "original_4": ["fact_accuracy", "structure_completeness", "readability", "insight_depth"],
    "new_3": ["interop_score", "latency_overhead", "token_efficiency"],
    "total": 7,
    "weights": {
      "fact_accuracy": 0.30,
      "structure_completeness": 0.15,
      "readability": 0.15,
      "insight_depth": 0.20,
      "interop_score": 0.10,
      "latency_overhead": 0.05,
      "token_efficiency": 0.05
    }
  },
  "hypotheses": {
    "H1": {
      "statement": "MCP 工具密集型任务（T1/T2）single-mcp 显著优于 single agent",
      "test_architectures": ["E13-A", "single"],
      "test_tasks": ["T1", "T2"],
      "primary_metric": "fact_accuracy",
      "statistical_test": "t-test + Cohen's d"
    },
    "H2": {
      "statement": "A2A 协作密集型任务（T4/T5）single-a2a 显著优于 single agent",
      "test_architectures": ["E13-B", "single"],
      "test_tasks": ["T4", "T5"],
      "primary_metric": "insight_depth",
      "statistical_test": "t-test + Cohen's d"
    },
    "H3": {
      "statement": "ain-routed 在涌现行为任务（T5）上表现最佳",
      "test_architectures": ["E13-D", "E13-A", "E13-B", "E13-C"],
      "test_tasks": ["T5"],
      "primary_metric": "insight_depth",
      "statistical_test": "ANOVA + post-hoc"
    },
    "H4": {
      "statement": "hybrid-mcp-a2a 在混合任务（T3）综合分最高",
      "test_architectures": ["E13-C", "E13-A", "E13-B", "E13-D"],
      "test_tasks": ["T3"],
      "primary_metric": "composite_score",
      "statistical_test": "ANOVA + post-hoc"
    }
  }
